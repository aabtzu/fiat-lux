.DS_Store

# User data (not for version control)
data/imports/
data/storage.json

# Environment files (may contain secrets)
.env
.env.local
.env.*.local

# Python agents service
agents/.env
agents/__pycache__/
agents/venv/
agents/**/__pycache__/
agents/**/*.pyc

# Python webapp
webapp/.env
webapp/.venv/
webapp/__pycache__/
webapp/**/__pycache__/
webapp/**/*.pyc
